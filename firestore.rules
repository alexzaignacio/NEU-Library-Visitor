rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string ('admin', 'student', 'faculty', 'staff')
    //   - status: string ('approved', 'pending_approval')
    //   - college_office: string
    //   - isBlocked: boolean
    //   - createdAt: timestamp
    //   - lastLogin: timestamp
    //
    // Collection: logs
    // Document ID: auto-generated
    // Fields:
    //   - userUid: string (required)
    //   - email: string
    //   - displayName: string
    //   - college: string
    //   - destination: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "alexzagayle.ignacio@neu.edu.ph" && request.auth.token.email_verified == true)
      );
    }

    function isStaff() {
      return isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff'));
    }

    function isFaculty() {
      return isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty'));
    }

    function isApproved() {
      return isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved');
    }

    function isNotBlocked() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status', 'isBlocked', 'createdAt', 'lastLogin']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student', 'faculty', 'staff'] &&
             data.status in ['approved', 'pending_approval'] &&
             data.isBlocked is bool &&
             data.createdAt is timestamp &&
             data.lastLogin is timestamp;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userUid', 'destination', 'timestamp']) &&
             data.userUid == request.auth.uid &&
             data.destination is string &&
             data.destination.size() > 0 &&
             data.destination.size() < 500 &&
             data.timestamp is timestamp;
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['userUid', 'room', 'date', 'status']) &&
             data.userUid == request.auth.uid &&
             data.room is string &&
             data.date is timestamp &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidResourceRequest(data) {
      return data.keys().hasAll(['userUid', 'title', 'justification', 'status', 'timestamp']) &&
             data.userUid == request.auth.uid &&
             data.title is string &&
             data.justification is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.timestamp is timestamp;
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'sku', 'stock', 'status']) &&
             data.name is string &&
             data.sku is string &&
             data.stock is number &&
             data.status is string;
    }

    function isValidFacilityRequest(data) {
      return data.keys().hasAll(['title', 'priority', 'status', 'timestamp']) &&
             data.title is string &&
             data.priority in ['High', 'Medium', 'Low'] &&
             data.status in ['pending', 'completed'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'student') || isAdmin()
      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.isBlocked == resource.data.isBlocked) ||
        isAdmin()
      );
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isApproved() && isNotBlocked() && isValidLog(request.resource.data);
      allow list: if isAdmin();
    }

    match /reservations/{resId} {
      allow read: if isOwner(resource.data.userUid) || isAdmin();
      allow create: if isAuthenticated() && isApproved() && isValidReservation(request.resource.data);
      allow update: if isAdmin();
    }

    match /resource_requests/{reqId} {
      allow read: if isOwner(resource.data.userUid) || isAdmin();
      allow create: if isFaculty() && isApproved() && isValidResourceRequest(request.resource.data);
      allow update: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isStaff() || isAdmin();
    }

    match /facility_requests/{reqId} {
      allow read: if isStaff() || isAdmin();
      allow create: if isStaff() || isAdmin();
      allow update: if isStaff() || isAdmin();
    }
  }
}
